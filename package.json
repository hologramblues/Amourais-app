{
  "name": "samourais-scrapper",
  "version": "1.0.0",
  "description": "Personal media scraper for Instagram, TikTok and Twitter/X with Google Drive upload",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vakra-dev/reader": "latest",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "express-handlebars": "^8.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "multer": "^2.0.2",
    "nanoid": "^5.0.0",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
