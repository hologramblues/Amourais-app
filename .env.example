# === SAMOURAIS SCRAPPER ===
# Copy this file to .env and fill in your values

PORT=8080
FLASK_DEBUG=1

# Google Drive OAuth2 (optional — only for gdrive storage mode)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
GOOGLE_REFRESH_TOKEN=
GDRIVE_ROOT_FOLDER_NAME=SAMOURAIS SCRAPPER

# Storage: "local" (save to disk) or "gdrive" (upload to Google Drive)
STORAGE_MODE=local

# Scraper Configuration
BROWSER_POOL_SIZE=2
DEFAULT_SCRAPE_INTERVAL_MINUTES=360
SCROLL_PAUSE_MS=3000
MAX_SCROLLS=30
BACKFILL_MAX_SCROLLS=200
DAILY_MAX_SCROLLS=15
DAILY_SCRAPE_INTERVAL_MINUTES=1440
DELAY_BETWEEN_PROFILES_MS=10000

# Storage Paths
DOWNLOAD_DIR=data/downloads
DB_PATH=data/samourais.db

# Logging
LOG_LEVEL=INFO
