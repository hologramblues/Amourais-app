<h1>Dashboard</h1>

<div class="grid">
  <article>
    <header>Profiles</header>
    <h2>{{stats.totalProfiles}}</h2>
    <small>{{stats.activeProfiles}} actifs</small>
  </article>
  <article>
    <header>Media total</header>
    <h2>{{stats.totalMedia}}</h2>
    <small>{{stats.uploadedMedia}} uploaded</small>
  </article>
  <article>
    <header>Jobs aujourd'hui</header>
    <h2>{{stats.todayJobs}}</h2>
    <small>{{stats.runningJobs}} en cours</small>
  </article>
  <article>
    <header>En attente</header>
    <h2>{{stats.pendingMedia}}</h2>
    <small>media a traiter</small>
  </article>
</div>

<section>
  <h2>Activite recente</h2>
  <div hx-get="/api/jobs/recent" hx-trigger="load, every 10s" hx-target="#recent-jobs">
    <div id="recent-jobs">
      <p aria-busy="true">Chargement...</p>
    </div>
  </div>
</section>

<section>
  <h2>Profiles suivis</h2>
  <table>
    <thead>
      <tr>
        <th>Plateforme</th>
        <th>Username</th>
        <th>Dernier scrape</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#each profiles}}
      <tr>
        <td>{{platformIcon this.platform}} {{this.platform}}</td>
        <td><a href="/profiles/{{this.id}}">{{this.username}}</a></td>
        <td>{{formatDate this.lastScrapedAt}}</td>
        <td>
          {{#if this.isActive}}
            <span style="color: green;">Actif</span>
          {{else}}
            <span style="color: gray;">Pause</span>
          {{/if}}
        </td>
        <td>
          <button
            class="outline small"
            hx-post="/api/profiles/{{this.id}}/scrape"
            hx-swap="none"
          >
            Scrape Now
          </button>
        </td>
      </tr>
      {{else}}
      <tr>
        <td colspan="5">Aucun profil. <a href="/profiles">Ajouter un profil</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</section>
